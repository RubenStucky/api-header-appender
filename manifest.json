{
    "manifest_version": 3,
    "name": "API Header Appender",
    "description": "Automatically inject API key headers and OAuth bearer tokens into requests based on URL patterns.",
    "version": "1.0.0",
    "icons": {
        "16": "icons/icon-16.png",
        "48": "icons/icon-48.png",
        "128": "icons/icon-128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon-16.png",
            "48": "icons/icon-48.png",
            "128": "icons/icon-128.png"
        }
    },
    "background": {
        "service_worker": "background.js",
        "type": "module"
    },
    "permissions": [
        "declarativeNetRequest",
        "declarativeNetRequestFeedback",
        "storage",
        "alarms",
        "tabs",
        "activeTab"
    ],
    "host_permissions": [
        "<all_urls>"
    ]
}